+++ b/packages/happy-app/src-tauri/Cargo.toml
@@ -21,6 +21,6 @@ tauri-build = { version = "2.4.0", features = [] }
 serde_json = "1.0"
 serde = { version = "1.0", features = ["derive"] }
 log = "0.4"
-tauri = { version = "~2.9", features = [] }
+tauri = { version = "~2.9", features = ["devtools"] }
 tauri-plugin-log = "2"
 tauri-plugin-http = "2"

-                    onPress={() => setModAudioEnabled(!modAudioEnabled)}
-                    showChevron={false}
-                />
-            </ItemGroup>
-
             <ItemGroup title={t('settingsMods.mod02Title')} footer={t('settingsMods.mod02Description')}>
                 <Item
                     title={t('settingsMods.enabled')}
